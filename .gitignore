# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.installed.cfg

# Test / coverage
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
nosetests.xml
coverage.xml

# =============================================================================
# Entornos virtuales
# =============================================================================
.env
.venv
env/
venv/
ENV/

# =============================================================================
# IDEs y OS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Logs del sistema (generados en runtime)
# =============================================================================
*.log
*.log.*
logs/

# =============================================================================
# Archivos de runtime de JSBach (generados dinámicamente, específicos por dispositivo)
# =============================================================================

# Trazas de ejecución/debug
last_sync_commands.txt
scenarios_*.txt

# PID files (runtime)
*.pid
jsbach.pid

# Scripts de prueba manuales / legacy (no son parte del sistema productivo)
app/modules/expect/scripts/master_cli_test.exp
app/modules/expect/scripts/wan.expect
*.expect

# =============================================================================
# Configuración por dispositivo (generada en instalación/runtime)
# No se clona: el instalador la genera a medida.
# =============================================================================

# Ignorar config por completo...
config/

# ...excepto los perfiles de hardware (son plantillas de código, no datos de dispositivo)
# NOTA: Para que funcione el untrack de un subdirectorio ignorado,
# los perfiles deben ser rastreados explícitamente:
!config/
!config/expect/
!config/expect/profiles/
!config/expect/profiles/*.json

# =============================================================================
# Archivos temporales
# =============================================================================
*.tmp
*.bak
*.backup
